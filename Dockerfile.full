FROM python:3.12-slim AS builder

WORKDIR /build

COPY pyproject.toml README.md LICENSE ./
COPY src/ src/

RUN pip install --no-cache-dir --target=/deps ".[zh,en,ja,ko,de,uk,in]" requests && \
    PYTHONPATH=/deps python -m spacy download en_core_web_sm && \
    PYTHONPATH=/deps python -m spacy download ja_core_news_sm && \
    PYTHONPATH=/deps python -m spacy download ko_core_news_sm && \
    PYTHONPATH=/deps python -m spacy download de_core_news_sm && \
    PYTHONPATH=/deps python -m spacy download xx_ent_wiki_sm

FROM python:3.12-slim

WORKDIR /app

COPY --from=builder /deps /usr/local/lib/python3.12/site-packages/
COPY --from=builder /build/src/ src/
COPY pyproject.toml README.md LICENSE ./

RUN pip install --no-cache-dir .

ENV OLLAMA_HOST=http://host.docker.internal:11434

ENTRYPOINT ["argus-redact"]
CMD ["info"]
