[
  {
    "id": "simple",
    "input": "邮箱zhang@example.com",
    "should_match": true,
    "type": "email",
    "expected_text": "zhang@example.com",
    "description": "标准邮箱"
  },
  {
    "id": "with_dots",
    "input": "john.doe@company.co.uk",
    "should_match": true,
    "type": "email",
    "description": "带点号和子域名"
  },
  {
    "id": "with_plus",
    "input": "user+tag@example.com",
    "should_match": true,
    "type": "email",
    "description": "带加号标签"
  },
  {
    "id": "with_subdomain",
    "input": "user@mail.example.co.uk",
    "should_match": true,
    "type": "email",
    "description": "多级子域名"
  },
  {
    "id": "not_email",
    "input": "这不是邮箱@",
    "should_match": false,
    "type": "email",
    "description": "不完整，不匹配"
  },
  {
    "id": "no_email_in_text",
    "input": "no email here",
    "should_match": false,
    "type": "email",
    "description": "纯文本，无邮箱"
  },
  {
    "id": "email_is_entire_text",
    "input": "zhang@example.com",
    "should_match": true,
    "type": "email",
    "expected_text": "zhang@example.com",
    "description": "整段文本就是邮箱"
  },
  {
    "id": "email_between_cjk",
    "input": "张三zhang@example.com李四",
    "should_match": true,
    "type": "email",
    "expected_text": "zhang@example.com",
    "description": "邮箱夹在中文之间"
  },
  {
    "id": "email_with_numbers",
    "input": "test123@gmail.com",
    "should_match": true,
    "type": "email",
    "expected_text": "test123@gmail.com",
    "description": "本地部分带数字"
  },
  {
    "id": "two_emails",
    "input": "a@b.com and c@d.com",
    "should_match": true,
    "type": "email",
    "description": "一段文字中两个邮箱"
  },
  {
    "id": "consecutive_dots_invalid",
    "input": "user..name@example.com",
    "should_match": false,
    "type": "email",
    "description": "连续点号不是有效邮箱 (RFC 5322)"
  },
  {
    "id": "leading_dot_invalid",
    "input": ".user@example.com",
    "should_match": false,
    "type": "email",
    "description": "点号开头不是有效邮箱"
  }
]
