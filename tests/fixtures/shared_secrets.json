        "should_match": true,
        "type": "openai_api_key",
        "expected_text": "sk-TEST1234567890abcdefghij1234567890ABCDEFGHIJ",
        "description": "OpenAI legacy sk- key, 48 chars after prefix"
    },
    {
        "id": "openai_sk_proj",
